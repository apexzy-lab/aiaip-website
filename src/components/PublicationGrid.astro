---
import { publications } from '@/data/site';
---
<div class="publication-grid">
  {publications.map((item) => (
    <article class="publication reveal">
      <a class:list={['cover', `cover-${item.cover}`]} href={`/research/${item.slug}`} aria-label={`Read ${item.title}`}>
        <span>{item.type} · {item.date}</span><h3>{item.title}</h3><i></i>
      </a>
      <p class="meta">{item.topic} · {item.readTime}</p><h3>{item.subtitle}</h3><a href={`/research/${item.slug}`}>Read publication →</a>
    </article>
  ))}
</div>
