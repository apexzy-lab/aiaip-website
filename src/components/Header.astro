---
import { navigation } from '@/data/site';
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="utility-bar">
    <div class="shell utility-inner">
      <div class="utility-points"><span><i></i>African agency.</span><span><i></i>Independent evidence.</span><span><i></i>Public-interest policy.</span></div>
      <nav aria-label="Utility navigation"><a href="/insights">News &amp; press</a><a href="/contact">Contact</a><span>EN</span></nav>
    </div>
  </div>
  <div class="shell nav-row">
    <a class="brand" href="/" aria-label="AIAIP homepage">
      <img class="header-logo" src="/brand/aiaip-logo-dark.png" width="337" height="92" alt="African Institute for Artificial Intelligence Policy" />
    </a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="primary-nav" data-menu><span></span><span></span><span></span><b>Menu</b></button>
    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation" data-nav>
      {navigation.map((item) => <a class:list={[path.startsWith(item.href) && 'active']} href={item.href}>{item.label}</a>)}
      <a class="button button-rust nav-cta" href="/get-involved">Work with us</a>
    </nav>
  </div>
</header>
