---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PageHero from '@/components/PageHero.astro'; import ContactCTA from '@/components/ContactCTA.astro'; import { stats } from '@/data/site';
---
<BaseLayout title="About" description="Learn about AIAIP's mission, independence and approach to African-led AI policy research."><PageHero eyebrow="About AIAIP" title="African evidence for decisions that shape our shared future." intro="We exist to ensure African perspectives, priorities and expertise influence how artificial intelligence is governed globally."/><section class="content-section section shell"><div class="editorial-grid"><h2>Research with purpose</h2><div><p class="large-copy">AIAIP is an independent research institution dedicated to advancing responsible and inclusive AI governance across Africa.</p><p>We connect rigorous research, economic analysis, policy design and stakeholder engagement. Our work is built for decision-makers—and grounded in the lives, institutions and ambitions of people across the continent.</p></div></div><div class="value-grid"><article><span>01</span><h3>African-led</h3><p>African knowledge and priorities are central, not supplementary.</p></article><article><span>02</span><h3>Independent</h3><p>Our analysis serves the public interest and follows the evidence.</p></article><article><span>03</span><h3>Actionable</h3><p>We translate research into practical pathways for institutions.</p></article></div></section><section class="about section"><div class="shell stats">{stats.map((stat) => <div class="stat"><strong>{stat.value}</strong><span>{stat.label}</span></div>)}</div></section><ContactCTA /></BaseLayout>
