---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ContactCTA from '@/components/ContactCTA.astro'; import { publications } from '@/data/site';
export function getStaticPaths() { return publications.map((item) => ({ params: { slug: item.slug }, props: { item } })); }
const { item } = Astro.props;
---
<BaseLayout title={item.title} description={item.subtitle}><article class="report-detail"><header class="report-hero"><div class="shell"><p class="eyebrow">{item.type} · {item.date}</p><h1>{item.title}</h1><p>{item.subtitle}</p><div class="report-meta"><span>{item.topic}</span><span>{item.readTime}</span><span>AIAIP Research Team</span></div></div></header><div class="article-body"><p class="large-copy">Africa’s choices about artificial intelligence will shape economic opportunity, public institutions and the rights of more than a billion people.</p><h2>Executive summary</h2><p>This demonstration article shows the publication format that will be used for AIAIP research. Final reports will include verified findings, methodology, authors, citations and downloadable files.</p><h2>Key questions</h2><ul><li>What policies can unlock inclusive and sustainable growth?</li><li>How should public institutions govern data and automated systems?</li><li>How can African priorities influence global standards?</li></ul><aside><strong>Publication status</strong><p>Demonstration content—replace with the approved report before launch.</p></aside></div></article><ContactCTA /></BaseLayout>
