---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AfricaMap from '@/components/AfricaMap.astro';
import PublicationGrid from '@/components/PublicationGrid.astro';
import ContactCTA from '@/components/ContactCTA.astro';
import { stats, themes } from '@/data/site';
---
<BaseLayout title="Home" description="African-led research and evidence advancing responsible AI governance across the continent.">
  <section class="hero">
    <div class="hero-copy reveal"><p class="eyebrow">Independent. African-led. Evidence-driven.</p><h1>Centering Africa in<br />Global AI Governance</h1><span class="small-rule"></span><p class="hero-lede">Evidence for an AI future shaped by 1.4 billion African voices.</p><div class="button-row"><a class="button button-green" href="/research">Explore our research <span>→</span></a><a class="button button-outline" href="/contact">Partner with us <span>→</span></a></div></div>
    <AfricaMap />
  </section>

  <section class="priority shell section">
    <article class="flagship reveal"><div class="flagship-copy"><p class="eyebrow">Flagship report</p><h2>Africa’s $1.2 Trillion<br />AI Opportunity</h2><p>A data-driven agenda for inclusive growth, jobs and innovation across the continent.</p><a class="text-link" href="/research/state-of-ai-in-africa">Read the report <span>→</span></a></div><div class="report-book"><span>AIAIP</span><h3>Africa’s<br />$1.2 Trillion<br />AI Opportunity</h3><p>Unlocking inclusive growth in the AI era</p></div></article>
    <div class="themes reveal"><div class="section-heading compact"><div><p class="eyebrow">Our research themes</p><h2>Evidence where it matters</h2></div></div><div class="theme-grid">{themes.map((theme) => <a class:list={['theme-card', theme.className]} href="/research"><span class="icon">◎</span><h3>{theme.title}</h3><p>{theme.summary}</p><b>Explore →</b></a>)}</div></div>
  </section>

  <section class="about section"><div class="shell about-grid"><div class="about-intro reveal"><p class="eyebrow light">About AIAIP</p><h2>Research.<br />Evidence.<br /><em>Impact.</em></h2></div><div class="about-copy reveal"><p class="large-copy">We are an independent African research institution advancing responsible AI governance across the continent.</p><p>Our work turns rigorous evidence into practical policy—ensuring African knowledge, needs and ambitions influence how AI is built and governed globally.</p><a class="button button-light" href="/about">Discover our approach <span>→</span></a></div></div><div class="shell stats">{stats.map((stat) => <div class="stat reveal"><strong>{stat.value}</strong><span>{stat.label}</span></div>)}</div></section>

  <section class="latest shell section"><div class="section-heading reveal"><div><p class="eyebrow">Latest research</p><h2>Ideas built for action</h2></div><a class="text-link" href="/insights">View all publications <span>→</span></a></div><PublicationGrid /></section>
  <section class="event-section section"><div class="shell event-card reveal"><div><p class="eyebrow light">Upcoming convening</p><h2>Africa AI Policy<br />Forum 2025</h2></div><div class="event-details"><span>Dates to be announced</span><span>Abuja, Nigeria</span><span>Policy leaders, researchers and builders</span></div><a class="button button-gold" href="/contact">Register interest <span>→</span></a></div></section>
  <ContactCTA />
</BaseLayout>
