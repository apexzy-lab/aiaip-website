---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PageHero from '@/components/PageHero.astro';
import { pageSeo } from '@/data/seo';
---
<BaseLayout title="Contact" {...pageSeo.contact}><PageHero eyebrow="Contact" title="Start a conversation with AIAIP." intro="Tell us about your research, policy, partnership or media enquiry."/><section class="section shell contact-layout"><div><h2>Get in touch</h2><p>Abuja, Federal Capital Territory<br/>Nigeria</p><p><a class="text-link" href="mailto:hello@africanaipolicy.org">hello@africanaipolicy.org →</a></p><p><a href="tel:+2348101885416">+234 810 188 5416</a></p></div><form class="contact-form" action="/thank-you" method="get"><label>Name<input name="name" required/></label><label>Email<input type="email" name="email" required/></label><label>Organization<input name="organization"/></label><label>How can we help?<textarea name="message" rows="6" required></textarea></label><button class="button button-rust" type="submit">Send enquiry →</button><p class="form-note">The production form handler and spam protection will be connected before launch.</p></form></section></BaseLayout>
