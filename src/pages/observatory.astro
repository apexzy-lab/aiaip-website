---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ContactCTA from '@/components/ContactCTA.astro';
---
<BaseLayout title="Africa AI Policy Observatory" description="AIAIP's planned public evidence platform for AI policy and implementation across Africa.">
  <PageHero
    eyebrow="In development"
    title="Africa AI Policy Observatory"
    intro="A public evidence platform designed to track not only whether AI policies exist, but whether institutions have the authority, resources and accountability to make them work."
  />
  <section class="section shell">
    <div class="editorial-grid">
      <h2 class="reveal">From policy announcements to implementation evidence</h2>
      <div class="reveal">
        <p class="large-copy">Africa needs a shared, trusted view of how AI governance is developing across the continent.</p>
        <p>The Observatory will organize national strategies, legislation, regulatory institutions, public-sector initiatives and implementation evidence into comparable country profiles.</p>
        <p>Its purpose is practical: help policymakers learn from peers, help researchers identify gaps and help the public understand whether commitments are becoming accountable institutions.</p>
      </div>
    </div>
    <div class="observatory-features">
      <article class="reveal"><span>01</span><h3>Country profiles</h3><p>Structured snapshots of strategies, laws, institutions and public initiatives.</p></article>
      <article class="reveal"><span>02</span><h3>Policy tracker</h3><p>A documented timeline of national and regional developments.</p></article>
      <article class="reveal"><span>03</span><h3>Implementation indicators</h3><p>Evidence about capacity, enforcement, participation and public accountability.</p></article>
      <article class="reveal"><span>04</span><h3>Open research layer</h3><p>Methods, sources and reusable datasets published for scrutiny and learning.</p></article>
    </div>
  </section>
  <section class="observatory-join">
    <div class="shell reveal"><p class="eyebrow light">Collaborate</p><h2>Help build the evidence base.</h2><p>We welcome conversations with researchers, public institutions and funders interested in methodology, country research or sustainable public infrastructure.</p><a class="button button-gold" href="/contact">Discuss the Observatory →</a></div>
  </section>
  <ContactCTA />
</BaseLayout>
