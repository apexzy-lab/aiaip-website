---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { pageSeo } from '@/data/seo';
---
<BaseLayout title="Work with us" {...pageSeo.getInvolved}>
  <PageHero
    eyebrow="Work with us"
    title="Build the institutions Africa needs for the AI age."
    intro="We work with partners who value independent evidence, serious engagement with context and policy that survives contact with implementation."
  />
  <section class="section shell">
    <div class="collaboration-grid">
      <article class="reveal"><span>Research</span><h2>Commission or co-create research</h2><p>Develop a rigorous evidence base around a shared public-interest question while protecting analytical independence.</p><a href="/contact">Discuss a research question →</a></article>
      <article class="reveal"><span>Institutions</span><h2>Strengthen policy capability</h2><p>Equip teams to evaluate options, design governance arrangements and prepare for implementation.</p><a href="/contact">Discuss institutional support →</a></article>
      <article class="reveal"><span>Networks</span><h2>Convene a difficult conversation</h2><p>Bring the right combination of public officials, researchers, civil society and technical experts into a trusted process.</p><a href="/contact">Plan a policy dialogue →</a></article>
      <article class="reveal"><span>Support</span><h2>Fund independent African evidence</h2><p>Support research infrastructure, fellowships and public resources that strengthen the wider AI policy field.</p><a href="/contact">Support the mission →</a></article>
    </div>
  </section>
  <section class="partner-standard">
    <div class="shell editorial-grid">
      <h2 class="reveal">The partners we are looking for</h2>
      <div class="reveal"><p class="large-copy">We value partners who want the most useful answer—not a predetermined one.</p><p>Good collaboration begins with clarity about the public purpose of the work, the independence of the research and how findings will reach people with the authority to act.</p><a class="button button-gold" href="/contact">Start a conversation →</a></div>
    </div>
  </section>
</BaseLayout>
