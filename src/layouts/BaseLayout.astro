---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  seoTitle?: string;
  keywords?: string[];
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'CollectionPage';
  additionalSchemas?: Record<string, unknown>[];
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  seoTitle,
  keywords = [],
  pageType = 'WebPage',
  additionalSchemas = [],
  image = '/social-card.svg',
  noindex = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site ?? new URL('https://africanaipolicy.org');
const pageTitle = seoTitle ?? (title === 'Home' ? 'African Institute for Artificial Intelligence Policy' : `${title} | AIAIP`);
const socialImage = new URL(image, Astro.site);
const organizationSchema = {
  '@type': 'ResearchOrganization',
  '@id': new URL('/#organization', siteUrl).href,
  name: 'African Institute for Artificial Intelligence Policy',
  alternateName: 'AIAIP',
  url: siteUrl.href,
  logo: new URL('/brand/aiaip-mark.png', siteUrl).href,
  description: 'Independent African research and policy for artificial intelligence governance in the public interest.',
  slogan: 'Centering Africa in Global AI Governance',
  foundingDate: '2025-03',
  founder: {
    '@type': 'Person',
    name: 'Uchechukwu Ajuzieogu',
    jobTitle: 'Founder & Executive Director',
    url: 'https://ajuzieogu.com',
  },
  parentOrganization: {
    '@type': 'ResearchOrganization',
    name: 'The Veridian Foundation',
    url: 'https://veridianfoundation.org',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Abuja',
    addressRegion: 'Federal Capital Territory',
    addressCountry: 'Nigeria',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'general enquiries',
    email: 'hello@africanaipolicy.org',
    telephone: '+234-810-188-5416',
  },
  areaServed: {
    '@type': 'Place',
    name: 'Africa',
  },
  sameAs: [
    'https://www.linkedin.com/company/aiaip/',
    'https://x.com/aiaipfdn',
  ],
};
const websiteSchema = {
  '@type': 'WebSite',
  '@id': new URL('/#website', siteUrl).href,
  name: 'African Institute for Artificial Intelligence Policy',
  alternateName: 'AIAIP',
  url: siteUrl.href,
  publisher: { '@id': new URL('/#organization', siteUrl).href },
  inLanguage: 'en',
};
const webpageSchema = {
  '@type': pageType,
  '@id': `${canonical.href}#webpage`,
  name: pageTitle,
  description,
  url: canonical.href,
  isPartOf: { '@id': new URL('/#website', siteUrl).href },
  about: { '@id': new URL('/#organization', siteUrl).href },
  inLanguage: 'en',
};
const breadcrumbSchema = Astro.url.pathname === '/' ? null : {
  '@type': 'BreadcrumbList',
  '@id': `${canonical.href}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl.href },
    { '@type': 'ListItem', position: 2, name: title, item: canonical.href },
  ],
};
const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    organizationSchema,
    websiteSchema,
    webpageSchema,
    ...(breadcrumbSchema ? [breadcrumbSchema] : []),
    ...additionalSchemas,
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="theme-color" content="#073e34" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/brand/aiaip-mark.png" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/brand/aiaip-mark.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AIAIP" />
    <meta property="og:locale" content="en_NG" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="African Institute for Artificial Intelligence Policy" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@aiaipfdn" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />

    <!-- Google tag (gtag.js): inherited by every page using this layout. -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-R1D4KKSQCZ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R1D4KKSQCZ');
    </script>

    <!-- Microsoft Clarity: inherited by every page using this layout. -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "uw5c3yedvi");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
    <script>
      const menu = document.querySelector('[data-menu]');
      const nav = document.querySelector('[data-nav]');
      menu?.addEventListener('click', () => {
        const open = nav?.classList.toggle('open') ?? false;
        menu.setAttribute('aria-expanded', String(open));
      });
      nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        nav.classList.remove('open');
        menu?.setAttribute('aria-expanded', 'false');
      }));
      const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      }), { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((node) => observer.observe(node));
    </script>
  </body>
</html>
